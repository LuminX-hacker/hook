{
  "_comment": "HTTP 方法级拦截规则 — DELETE 和 PATCH 拦截，PUT 放行",
  "version": "2.1",
  "_design": "DELETE=删除资源 PATCH=部分修改，均拦截。PUT 放行供渗透测试。",
  "blocked_methods": {
    "critical": ["DELETE"],
    "high": ["PATCH"],
    "_note_put_allowed": "PUT 已开放，allow_put: true",
    "_note_get_safe": "GET/HEAD/OPTIONS 永远放行"
  },
  "tool_patterns": {
    "_doc": "不同HTTP客户端工具中指定危险方法的写法（PUT 已移除）",
    "curl": [
      {"pattern": "\\bcurl\\s+.*(-X\\s+|--request\\s+)(DELETE|PATCH)\\b", "description": "curl 指定危险HTTP方法（DELETE/PATCH）"},
      {"pattern": "\\bcurl\\s+.*--method\\s*(DELETE|PATCH)\\b", "description": "curl --method 指定危险HTTP方法"}
    ],
    "wget": [
      {"pattern": "\\bwget\\s+.*--method=(DELETE|PATCH)\\b", "description": "wget 指定危险HTTP方法"}
    ],
    "httpie": [
      {"pattern": "\\bhttp\\s+(DELETE|PATCH)\\b", "description": "httpie 指定危险HTTP方法"}
    ],
    "powershell": [
      {"pattern": "-Method\\s+(DELETE|PATCH)\\b", "description": "PowerShell Invoke-WebRequest 指定危险方法"},
      {"pattern": "Invoke-RestMethod.*-Method\\s+(DELETE|PATCH)\\b", "description": "PowerShell Invoke-RestMethod 指定危险方法"}
    ],
    "python_requests": [
      {"pattern": "requests\\.(delete|patch)\\(", "description": "Python requests 危险方法"},
      {"pattern": "\\.request\\(\\s*['\"]?(DELETE|PATCH)['\"]?", "description": "Python requests.request 指定危险方法"}
    ],
    "generic": [
      {"pattern": "\\b(DELETE|PATCH)\\s+/\\S+\\s+HTTP/", "description": "原始HTTP请求中的危险方法"},
      {"pattern": "-X\\s*(DELETE|PATCH)\\b", "description": "通用 -X 指定危险HTTP方法"}
    ]
  }
}
