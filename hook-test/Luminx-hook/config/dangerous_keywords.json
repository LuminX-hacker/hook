{
  "_comment": "通用危险操作关键词 — 匹配任何URL/路径中的破坏性操作语义，不限定特定API结构",
  "version": "2.0",
  "_design": "与具体业务路径无关，只匹配操作语义。例如 /anything/delete 或 /xxx/remove/yyy 都会被拦截",
  "url_segment_keywords": {
    "_doc": "URL路径段中出现的危险操作关键词（匹配任意位置，不限API版本号/结构）",
    "critical": [
      {"keyword": "delete", "description": "删除操作"},
      {"keyword": "remove", "description": "移除操作"},
      {"keyword": "destroy", "description": "销毁操作"},
      {"keyword": "purge", "description": "清除操作"},
      {"keyword": "truncate", "description": "截断操作"},
      {"keyword": "drop", "description": "丢弃/删除操作"},
      {"keyword": "wipe", "description": "擦除操作"},
      {"keyword": "erase", "description": "抹除操作"}
    ],
    "high": [
      {"keyword": "reset", "description": "重置操作"},
      {"keyword": "clear", "description": "清空操作"},
      {"keyword": "flush", "description": "刷新/清空操作"},
      {"keyword": "shutdown", "description": "关闭操作"},
      {"keyword": "terminate", "description": "终止操作"},
      {"keyword": "deactivate", "description": "停用操作"},
      {"keyword": "revoke", "description": "撤销操作"},
      {"keyword": "invalidate", "description": "使失效操作"}
    ],
    "medium": [
      {"keyword": "update", "description": "更新操作（配合PUT/PATCH方法时拦截）"},
      {"keyword": "modify", "description": "修改操作（配合PUT/PATCH方法时拦截）"},
      {"keyword": "change", "description": "变更操作（配合PUT/PATCH方法时拦截）"},
      {"keyword": "config", "description": "配置操作（配合PUT/PATCH/DELETE方法时拦截）"}
    ]
  },
  "body_keywords": {
    "_doc": "请求体/参数中的危险关键词模式",
    "patterns": [
      {"pattern": "\"action\"\\s*:\\s*\"(delete|remove|destroy|purge|drop|truncate)\"", "description": "JSON body 中的破坏性操作声明", "severity": "critical"},
      {"pattern": "\"operation\"\\s*:\\s*\"(delete|remove|destroy|purge|drop|truncate)\"", "description": "JSON body 中的破坏性操作声明", "severity": "critical"},
      {"pattern": "\"method\"\\s*:\\s*\"(DELETE|PUT|PATCH)\"", "description": "JSON body 中的危险HTTP方法声明", "severity": "high"},
      {"pattern": "\\$\\w+\\s*\\{.*\\}", "description": "可能的模板注入/SSTI载荷", "severity": "medium"}
    ]
  },
  "safe_patterns": {
    "_doc": "安全模式白名单 — 匹配这些模式的操作不会被拦截（即使包含上述关键词）",
    "description": "渗透测试中的正常操作：信息收集、扫描、读取等",
    "allow_get_methods": true,
    "allow_head_options": true,
    "url_whitelist_keywords": [
      "list", "search", "query", "get", "fetch", "read", "view", "check", "verify",
      "scan", "detect", "test", "probe", "enumerate", "info", "detail", "count",
      "health", "status", "ping", "echo", "version", "whoami", "me"
    ]
  }
}
