{
  "_comment": "严重破坏性操作规则 — 始终拦截，不可覆盖",
  "version": "1.0",
  "rules": [
    {
      "id": "destroy_rm_rf",
      "pattern": "\\brm\\s+(-[a-zA-Z]*r[a-zA-Z]*f[a-zA-Z]*|-[a-zA-Z]*f[a-zA-Z]*r[a-zA-Z]*)\\b",
      "description": "rm -rf 强制递归删除",
      "severity": "critical"
    },
    {
      "id": "destroy_rm_root",
      "pattern": "\\brm\\s+(/|/etc|/var|/usr|/home|/opt|/tmp|/root)\\b",
      "description": "rm 删除系统根目录",
      "severity": "critical"
    },
    {
      "id": "destroy_del_tree",
      "pattern": "\\b(del|erase)\\s+(/[sS]\\s+|[sS]:\\s+)",
      "description": "Windows del /s 递归删除",
      "severity": "critical"
    },
    {
      "id": "destroy_rmdir_s",
      "pattern": "\\brmdir\\s+(/[sS]\\s+|[sS]:\\s+)",
      "description": "Windows rmdir /s 递归删除目录",
      "severity": "critical"
    },
    {
      "id": "destroy_format",
      "pattern": "\\bformat\\s+[A-Za-z]:",
      "description": "Windows format 格式化磁盘",
      "severity": "critical"
    },
    {
      "id": "destroy_diskpart",
      "pattern": "\\bdiskpart\\b",
      "description": "Windows diskpart 磁盘分区操作",
      "severity": "critical"
    },
    {
      "id": "destroy_dd",
      "pattern": "\\bdd\\s+.*of=/dev/",
      "description": "dd 写入裸设备",
      "severity": "critical"
    },
    {
      "id": "destroy_raw_disk",
      "pattern": ">\\s*/dev/sd[a-z]",
      "description": "直接写入裸磁盘设备",
      "severity": "critical"
    },
    {
      "id": "destroy_shutdown",
      "pattern": "\\b(shutdown|poweroff|halt|init\\s+[06])\\b",
      "description": "关机/重启命令",
      "severity": "critical"
    },
    {
      "id": "destroy_reboot",
      "pattern": "\\breboot\\b",
      "description": "重启系统",
      "severity": "critical"
    },
    {
      "id": "destroy_iptables",
      "pattern": "\\biptables\\s+(-F|--flush|-X|--delete-chain)\\b",
      "description": "清空防火墙规则",
      "severity": "critical"
    },
    {
      "id": "destroy_netsh",
      "pattern": "\\bnetsh\\s+(advfirewall|firewall)\\s+set\\s+opmode\\s+mode=disable",
      "description": "Windows 关闭防火墙",
      "severity": "critical"
    },
    {
      "id": "destroy_chmod_777",
      "pattern": "\\bchmod\\s+(-R\\s+)?777\\b",
      "description": "chmod 777 全开权限",
      "severity": "high"
    },
    {
      "id": "destroy_mkfs",
      "pattern": "\\bmkfs\\.",
      "description": "格式化文件系统",
      "severity": "critical"
    },
    {
      "id": "destroy_sysctl",
      "pattern": "\\bsysctl\\s+-w\\s+kernel",
      "description": "修改内核参数",
      "severity": "high"
    }
  ],
  "sql_destruction": [
    {
      "id": "sql_drop",
      "pattern": "\\bDROP\\s+(TABLE|DATABASE|SCHEMA)\\b",
      "description": "SQL DROP 删除表/库",
      "severity": "critical"
    },
    {
      "id": "sql_truncate",
      "pattern": "\\bTRUNCATE\\s+(TABLE\\s+)?",
      "description": "SQL TRUNCATE 清空表",
      "severity": "critical"
    },
    {
      "id": "sql_delete",
      "pattern": "\\bDELETE\\s+FROM\\b",
      "description": "SQL DELETE FROM 删除数据",
      "severity": "critical"
    },
    {
      "id": "sql_update_no_where",
      "pattern": "\\bUPDATE\\s+\\w+\\s+SET\\b(?!.+\\bWHERE\\b)",
      "description": "SQL UPDATE 无 WHERE 条件",
      "severity": "high"
    },
    {
      "id": "sql_alter_drop",
      "pattern": "\\bALTER\\s+(TABLE|DATABASE)\\s+\\w+\\s+DROP\\b",
      "description": "SQL ALTER DROP 删除列",
      "severity": "high"
    }
  ]
}
