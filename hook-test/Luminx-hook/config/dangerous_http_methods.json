{
  "_comment": "HTTP 方法级拦截规则 — 仅拦截不可逆 DELETE，PUT/PATCH 放行",
  "version": "2.1",
  "_design": "DELETE=删除资源 拦截。PUT/PATCH=修改/上传 放行供渗透测试。",
  "blocked_methods": {
    "critical": ["DELETE"],
        "_note_put_allowed": "PUT 已开放，allow_put: true",
    "_note_get_safe": "GET/HEAD/OPTIONS 永远放行"
  },
  "tool_patterns": {
    "_doc": "不同HTTP客户端工具中指定 DELETE 方法的写法（PUT/PATCH 已移除）",
    "curl": [
      {"pattern": "\\bcurl\\s+.*(-X\\s+|--request\\s+)DELETE\\b", "description": "curl 指定 DELETE 方法"},
      {"pattern": "\\bcurl\\s+.*--method\\s*DELETE\\b", "description": "curl --method DELETE 请求"}
    ],
    "wget": [
      {"pattern": "\\bwget\\s+.*--method=DELETE\\b", "description": "wget --method DELETE 请求"}
    ],
    "httpie": [
      {"pattern": "\\bhttp\\s+DELETE\\b", "description": "httpie DELETE 请求"}
    ],
    "powershell": [
      {"pattern": "-Method\\s+DELETE\\b", "description": "PowerShell Invoke-WebRequest DELETE 方法"},
      {"pattern": "Invoke-RestMethod.*-Method\\s+DELETE\\b", "description": "PowerShell Invoke-RestMethod DELETE 请求"}
    ],
    "python_requests": [
      {"pattern": "requests\\.delete\\(", "description": "Python requests DELETE 方法"},
      {"pattern": "\\.request\\(\\s*['\"]?DELETE['\"]?", "description": "Python requests.request DELETE 请求"}
    ],
    "generic": [
      {"pattern": "\\bDELETE\\s+/\\S+\\s+HTTP/", "description": "原始 HTTP 请求中的 DELETE 方法"},
      {"pattern": "-X\\s*DELETE\\b", "description": "通用 -X 指定 DELETE 方法"}
    ]
  }
}
